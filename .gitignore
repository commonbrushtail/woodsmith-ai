# Supabase CLI temp files
supabase/.temp/

# Self-hosted Supabase stack: the SOURCE (compose, scripts, config) is tracked.
# Runtime data + secrets are ignored by supabase/docker/.gitignore
# (volumes/*/data, volumes/storage, .env). Do NOT blanket-ignore the whole dir —
# that silently drops new stack files (compose overlays, scripts) from commits.

