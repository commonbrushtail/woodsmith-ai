# Build context excludes — keep the image small and avoid leaking local state.

# deps + build output (rebuilt inside the image)
node_modules
.next
out

# secrets / local env (NEXT_PUBLIC_* come in via --build-arg; server secrets at runtime)
.env
.env.*
!.env.example

# vcs / tooling / editor
.git
.gitignore
.claude
.vscode
.idea

# infra not needed in the app image (DB stack + migrations applied separately)
supabase
scripts

# tests / e2e artifacts
tests
playwright.config.js
playwright-report
test-results
.playwright-mcp
coverage
vitest.config.js

# planning / docs
.planning
docs
*.md

# docker meta
Dockerfile
.dockerignore
docker-compose*.yml

# misc
npm-debug.log*
*.log
