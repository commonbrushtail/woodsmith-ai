# Database password for the hosted WoodSmith Supabase project.
# Dashboard -> Settings -> Database -> Database password (reset there if unknown).
#
# Copy this file to  supabase/.db-credentials.local  and paste the password.
# The real file matches *.local in .gitignore, so it is never committed.
# Used by scripts/db-push.ps1 to apply migrations without the CLI global login.
SUPABASE_DB_PASSWORD=
