# Files mounted into Linux containers MUST use LF line endings.
# Windows checkouts otherwise break entrypoint scripts and Elixir configs.
*.sh           text eol=lf
*.exs          text eol=lf
*.yaml         text eol=lf
*.yml          text eol=lf
*.sql          text eol=lf
*.conf         text eol=lf
*.tpl          text eol=lf
Caddyfile      text eol=lf
docker-compose.*.yml text eol=lf
docker-compose.yml   text eol=lf
